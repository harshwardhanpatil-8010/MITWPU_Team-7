                                <color key="textColor" systemColor="secondaryLabelColor"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <progressView opaque="NO" contentMode="scaleToFill" verticalHuggingPriority="750" progress="0.5" translatesAutoresizingMaskIntoConstraints="NO" id="SS-Game-Prog">
                                <rect key="frame" x="40" y="750" width="313" height="4"/>
                                <color key="progressTintColor" systemColor="systemGreenColor"/>
                            </progressView>
                        </subviews>
                        <viewLayoutGuide key="safeArea" id="SS-Game-Safe"/>
                        <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                        <constraints>
                            <constraint firstItem="SS-SK-View" firstAttribute="leading" secondItem="SS-Game-View" secondAttribute="leading" id="SS-G1"/>
                            <constraint firstItem="SS-Game-Feedback" firstAttribute="leading" secondItem="SS-Game-Safe" secondAttribute="leading" constant="40" id="SS-G10"/>
                            <constraint firstItem="SS-Game-Safe" firstAttribute="bottom" secondItem="SS-Game-Prog" secondAttribute="bottom" constant="30" id="SS-G11"/>
                            <constraint firstItem="SS-Game-Prog" firstAttribute="leading" secondItem="SS-Game-Safe" secondAttribute="leading" constant="40" id="SS-G12"/>
                            <constraint firstItem="SS-Game-Safe" firstAttribute="trailing" secondItem="SS-Game-Prog" secondAttribute="trailing" constant="40" id="SS-G13"/>
                            <constraint firstItem="SS-SK-View" firstAttribute="top" secondItem="SS-Game-View" secondAttribute="top" id="SS-G2"/>
                            <constraint firstAttribute="trailing" secondItem="SS-SK-View" secondAttribute="trailing" id="SS-G3"/>
