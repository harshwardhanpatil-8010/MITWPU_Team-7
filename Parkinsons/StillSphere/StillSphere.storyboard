                            <constraint firstItem="SS-HowToPlay-Content" firstAttribute="top" secondItem="SS-HowToPlay-Title" secondAttribute="bottom" constant="7" id="SS-I-C15"/>
                            <constraint firstItem="SS-Daily-Content" firstAttribute="leading" secondItem="SS-Info-Safe" secondAttribute="leading" constant="16" id="SS-I-C16"/>
                            <constraint firstItem="SS-HowToPlay-Title" firstAttribute="leading" secondItem="SS-Info-Safe" secondAttribute="leading" constant="16" id="SS-I-C17"/>
