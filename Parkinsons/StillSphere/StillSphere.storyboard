                                            </connections>
                                        </barButtonItem>
                                    </navigationItem>
                                </items>
                            </navigationBar>
                        </subviews>
                        <viewLayoutGuide key="safeArea" id="SS-Info-Safe"/>
                        <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                        <constraints>
                            <constraint firstAttribute="trailing" secondItem="SS-NavBar" secondAttribute="trailing" id="SS-I-C1"/>
                            <constraint firstItem="SS-Info-Safe" firstAttribute="trailing" secondItem="SS-HowToPlay-Title" secondAttribute="trailing" constant="16" id="SS-I-C10"/>
                            <constraint firstAttribute="trailing" secondItem="SS-Separator" secondAttribute="trailing" constant="16" id="SS-I-C11"/>
                            <constraint firstItem="SS-Info-Safe" firstAttribute="trailing" secondItem="SS-Daily-Title" secondAttribute="trailing" constant="16" id="SS-I-C12"/>
                            <constraint firstItem="SS-Info-Safe" firstAttribute="trailing" secondItem="SS-Daily-Content" secondAttribute="trailing" constant="16" id="SS-I-C13"/>
