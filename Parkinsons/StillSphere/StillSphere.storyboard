        <!--Still Sphere Info View Controller-->
        <scene sceneID="SS-Info-Scene">
            <objects>
                <viewController storyboardIdentifier="StillSphereInfoViewController" useStoryboardIdentifierAsRestorationIdentifier="YES" id="SS-Info-VC" customClass="StillSphereInfoViewController" customModule="ParkyCare" customModuleProvider="target" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="SS-Info-View">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="SS-HowToPlay-Content">
                                <rect key="frame" x="16" y="113.00000000000001" width="361" height="218.33333333333337"/>
                                <string key="text">1. You’ll see a glowing sphere on the screen.
2. You need to tilt your phone to move the sphere along the path.
3. Guide the sphere toward the glowing target circle.
4. Move slowly and steadily for better control.
5. Avoid sudden fast tilts to keep the sphere from drifting.
6. Reach the glowing calm zone to complete the session.</string>
                                <fontDescription key="fontDescription" style="UICTFontTextStyleBody"/>
                                <nil key="textColor"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Daily challenges" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="SS-Daily-Title">
                                <rect key="frame" x="16" y="362.33333333333331" width="361" height="21"/>
                                <fontDescription key="fontDescription" style="UICTFontTextStyleHeadline"/>
                                <nil key="textColor"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="SS-Daily-Content">
                                <rect key="frame" x="16" y="390.33333333333331" width="361" height="174.33333333333331"/>
                                <string key="text">1. Everyday brings a brand-new path to navigate.
2. New daily challenges help improve hand control and steadiness.
3. Take your time, you can retry the challenge whenever you want.
4. Complete the daily set to track your progress over time.</string>
                                <fontDescription key="fontDescription" style="UICTFontTextStyleBody"/>
                                <nil key="textColor"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="How to Play ?" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="SS-HowToPlay-Title">
                                <rect key="frame" x="16" y="85" width="361" height="21"/>
                                <fontDescription key="fontDescription" style="UICTFontTextStyleHeadline"/>
                                <nil key="textColor"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="SS-Separator">
                                <rect key="frame" x="16" y="346.33333333333331" width="361" height="1"/>
                                <color key="backgroundColor" systemColor="separatorColor"/>
                                <constraints>
                                    <constraint firstAttribute="height" constant="1" id="SS-Sep-H"/>
                                </constraints>
                            </view>
                            <navigationBar contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="SS-NavBar">
                                <rect key="frame" x="0.0" y="15" width="393" height="54"/>
                                <items>
                                    <navigationItem id="SS-NavItems">
                                        <barButtonItem key="leftBarButtonItem" title="Item" image="xmark" catalog="system" id="SS-Close-Btn">
                                            <connections>
