                            <constraint firstItem="SS-Daily-Title" firstAttribute="leading" secondItem="SS-Info-Safe" secondAttribute="leading" constant="16" id="SS-I-C2"/>
                            <constraint firstItem="SS-Info-Safe" firstAttribute="trailing" secondItem="SS-HowToPlay-Content" secondAttribute="trailing" constant="16" id="SS-I-C3"/>
